NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_BASE_URL=http://localhost:5001

# Production values (fill after deployment)
# NEXT_PUBLIC_API_URL=https://college-delhi-backend.vercel.app/api
# NEXT_PUBLIC_BASE_URL=https://collegedelhi.com

# Anthropic AI (for AI chat, comparisons, recommendations)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Email (Nodemailer - for lead notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@collegedelhi.com
NOTIFICATION_EMAIL=admin@collegedelhi.com

# IndexNow (SEO)
INDEXNOW_KEY=your_indexnow_key_here
